<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Scanlation Toolkit V2.1 - Hiç Kimse</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap');
        body { font-family: 'JetBrains Mono', monospace; }
        .custom-scrollbar::-webkit-scrollbar { width: 6px; height: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #111217; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #ecec00; border-radius: 3px; }
        
        .text-custom-yellow { color: #ecec00; }
        .bg-custom-yellow { background-color: #ecec00; }
        .border-custom-yellow { border-color: #ecec00; }
        .accent-custom-yellow { accent-color: #ecec00; }

        .gc-1 { background-color: rgba(236, 236, 0, 0.08) !important; border-color: #ecec00 !important; color: #ecec00 !important; }
        .gc-2 { background-color: rgba(57, 255, 24, 0.08) !important; border-color: #39ff14 !important; color: #39ff14 !important; }
        .gc-3 { background-color: rgba(255, 157, 0, 0.08) !important; border-color: #ff9d00 !important; color: #ff9d00 !important; }
        .gc-4 { background-color: rgba(255, 0, 127, 0.08) !important; border-color: #ff007f !important; color: #ff007f !important; }
        .gc-5 { background-color: rgba(189, 0, 255, 0.08) !important; border-color: #bd00ff !important; color: #bd00ff !important; }

        .comparison-slider { position: relative; width: 100%; overflow: hidden; }
        .comparison-slider .resize { position: absolute; top: 0; left: 0; height: 100%; width: 50%; overflow: hidden; z-index: 2; }
        .comparison-slider .handle { position: absolute; top: 0; bottom: 0; left: 50%; width: 4px; background: #ecec00; cursor: ew-resize; z-index: 3; box-shadow: 0 0 10px rgba(236,236,0,0.8); }
        .comparison-slider .handle::after { content: '◀ ▶'; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: #111217; border: 1px solid #ecec00; color: #ecec00; font-size: 10px; font-weight: bold; padding: 2px 4px; border-radius: 4px; white-space: nowrap; }
        
        /* Çizgi kapalıyken slider serbest kalsın */
        .comparison-slider.disabled .resize { width: 100% !important; position: static; overflow: visible; }
        .comparison-slider.disabled .handle { display: none !important; }

        /* Photoshop Crop Çizgileri */
        .crop-guide-line { position: absolute; left: 0; right: 0; height: 2px; background: #ecec00; cursor: ns-resize; z-index: 10; box-shadow: 0 0 5px rgba(236,236,0,0.7); }
        .crop-guide-line::after { content: attr(data-label); position: absolute; right: 10px; background: #111217; color: #ecec00; font-size: 9px; padding: 1px 4px; border: 1px solid #ecec00; border-radius: 3px; transform: translateY(-50%); }

        /* Sürükle-Bırak Stilleri */
        .drag-over-upload { border-color: #ecec00 !important; background-color: rgba(236,236,0,0.12) !important; }
        .drag-over-upload span { color: #ecec00 !important; }
        #global-drop-zone { pointer-events: none; }
        #global-drop-zone.active { pointer-events: all; }
    </style>
</head>
<body class="bg-[#07080a] text-gray-200 h-screen flex flex-col overflow-hidden select-none relative">

    <!-- Global Sürükle-Bırak Overlay -->
    <div id="global-drop-zone" class="fixed inset-0 z-50 bg-black/70 flex items-center justify-center hidden">
        <div class="border-2 border-dashed border-custom-yellow rounded-2xl px-20 py-14 text-center pointer-events-none">
            <i data-lucide="upload-cloud" class="w-16 h-16 text-custom-yellow mx-auto mb-4"></i>
            <p class="text-custom-yellow font-bold text-lg tracking-widest">DOSYALARI BIRAK</p>
            <p class="text-gray-400 text-xs mt-2">Görseller otomatik yüklenecek</p>
        </div>
    </div>

    <header class="bg-[#111217] border-b border-gray-800 px-6 py-3 flex flex-wrap items-center justify-between gap-4 z-20">
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded bg-[#ecec00]/10 border border-custom-yellow flex items-center justify-center">
                <i data-lucide="terminal" class="text-custom-yellow w-4 h-4"></i>
            </div>
            <div>
                <h1 class="text-xs font-bold tracking-wider text-custom-yellow">SCANLATION TOOLKIT // V2.1</h1>
                <p class="text-[9px] text-gray-500 font-bold">DEVELOPED BY HIÇ KIMSE</p>
            </div>
        </div>

        <div class="flex flex-wrap gap-1.5">
            <button onclick="changeEngine('merger')" id="tab-merger" class="px-3 py-1.5 rounded text-xs font-bold transition-all border flex items-center gap-1.5 bg-[#ecec00]/10 border-custom-yellow text-custom-yellow">
                <i data-lucide="link" class="w-3.5 h-3.5"></i> PANEL BİRLEŞTİRİCİ
            </button>
            <button onclick="changeEngine('splitter')" id="tab-splitter" class="px-3 py-1.5 rounded text-xs font-bold transition-all border flex items-center gap-1.5 bg-gray-900 border-gray-800 text-gray-400 hover:text-white">
                <i data-lucide="scissors" class="w-3.5 h-3.5"></i> DİKEY AYIRICI
            </button>
            <button onclick="changeEngine('converter')" id="tab-converter" class="px-3 py-1.5 rounded text-xs font-bold transition-all border flex items-center gap-1.5 bg-gray-900 border-gray-800 text-gray-400 hover:text-white">
                <i data-lucide="sliders" class="w-3.5 h-3.5"></i> FİLTRELER & LEVELS
            </button>
            <button onclick="changeEngine('renamer')" id="tab-renamer" class="px-3 py-1.5 rounded text-xs font-bold transition-all border flex items-center gap-1.5 bg-gray-900 border-gray-800 text-gray-400 hover:text-white">
                <i data-lucide="binary" class="w-3.5 h-3.5"></i> ARDIL ADLANDIRICI
            </button>
            <button onclick="changeEngine('watermark')" id="tab-watermark" class="px-3 py-1.5 rounded text-xs font-bold transition-all border flex items-center gap-1.5 bg-gray-900 border-gray-800 text-gray-400 hover:text-white">
                <i data-lucide="image" class="w-3.5 h-3.5"></i> WATERMARK MOTORU
            </button>
        </div>

        <div class="text-right font-mono text-[10px] text-gray-500 hidden xl:block">
            OTOMATİK KAYIT: <span id="save-status" class="text-emerald-400 font-bold">AKTİF</span>
        </div>
    </header>

    <div class="flex-1 flex overflow-hidden">
        
        <aside class="w-80 bg-[#111217]/90 border-r border-gray-800 p-4 flex flex-col justify-between overflow-y-auto custom-scrollbar">
            <div class="space-y-4">
                <div class="p-3 bg-gray-950 rounded border border-gray-800 text-[10px] text-gray-400 space-y-1">
                    <div class="text-custom-yellow font-bold flex items-center gap-1 mb-1"><i data-lucide="command" class="w-3 h-3"></i> SİSTEM NOTLARI:</div>
                    <p>• Görsel kırpma için panele <kbd class="bg-gray-800 px-1 text-white">Çift Tıklayın</kbd>.</p>
                    <p>• Gruplama için <kbd class="bg-gray-800 px-1 text-white">Shift+Tık</kbd> yapıp <kbd class="bg-gray-800 px-1 text-white">G</kbd> basın.</p>
                    <p>• Geri almak için <kbd class="bg-gray-800 px-1 text-white">Ctrl+Z</kbd> basın.</p>
                </div>

                <div class="space-y-1.5">
                    <label class="text-[10px] font-bold text-gray-400 tracking-wider uppercase">KAYNAK RAW GÖRSELLERİ</label>
                    <label id="upload-drop-zone" class="w-full h-10 border border-dashed border-gray-700 hover:border-custom-yellow bg-gray-950 rounded flex items-center justify-center gap-2 text-xs text-gray-400 cursor-pointer transition-colors">
                        <i data-lucide="upload-cloud" class="w-4 h-4 text-custom-yellow"></i>
                        <span>RAW Dosyalarını Seçin veya Sürükleyin</span>
                        <input type="file" id="universal-loader" multiple accept="image/*" class="hidden" onchange="processFiles(event)">
                    </label>
                </div>

                <div id="core-merger" class="engine-settings space-y-4">
                    <div class="p-3 bg-gray-950 border border-gray-800 rounded space-y-2.5">
                        <div class="text-custom-yellow font-bold text-[10px]">BİRLEŞTİRME YÖNTEMİ</div>
                        <div class="flex items-center gap-2">
                            <input type="checkbox" id="mAutoMode" class="accent-custom-yellow h-4 w-4 rounded bg-gray-900 border-gray-700" onchange="toggleMergerAutoUI()">
                            <label for="mAutoMode" class="text-xs text-gray-300 cursor-pointer select-none">Otomatik Piksel Limitini Aktif Et</label>
                        </div>
                        <div id="mAutoHeightBox" class="space-y-1 hidden">
                            <label class="text-[9px] text-gray-400 block">Hedef Sayfa Yüksekliği (PX):</label>
                            <input type="number" id="mTargetHeight" value="8000" class="w-full bg-[#181a22] border border-gray-700 rounded p-1.5 text-xs text-gray-200 focus:outline-none focus:border-custom-yellow">
                        </div>
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-[10px] font-bold text-gray-400 tracking-wider uppercase">ÇIKTI ZIP ADI</label>
                        <input type="text" id="mZipName" placeholder="birlesmis_bolum_panelleri" class="w-full bg-[#181a22] border border-gray-700 rounded p-2 text-xs text-gray-200 focus:outline-none focus:border-custom-yellow">
                    </div>
                    <div id="mManualButtons" class="space-y-2">
                        <button onclick="buildGroup()" class="w-full bg-gray-800 hover:bg-gray-700 text-white font-bold py-2 px-3 rounded text-xs flex items-center justify-center gap-1.5 border border-gray-700">
                            <i data-lucide="folder-plus" class="w-3.5 h-3.5 text-custom-yellow"></i> Seçilenleri Grupla (G)
                        </button>
                    </div>
                    <button onclick="compileMerger()" class="w-full bg-custom-yellow hover:bg-[#d0d000] text-gray-950 font-bold py-2.5 px-3 rounded text-xs flex items-center justify-center gap-1.5 shadow-md">
                        <i data-lucide="zap" class="w-4 h-4"></i> DERLE VE BİRLEŞTİR (Z)
                    </button>
                </div>

                <div id="core-splitter" class="engine-settings space-y-4 hidden">
                    <div class="space-y-1.5">
                        <label class="text-[10px] font-bold text-gray-400 tracking-wider uppercase">MAKSİMUM PARÇA YÜKSEKLİĞİ (PX)</label>
                        <input type="number" id="sHeight" value="3500" class="w-full bg-[#181a22] border border-gray-700 rounded p-2 text-xs text-gray-200 focus:outline-none focus:border-custom-yellow">
                    </div>
                    <div class="p-3 bg-gray-950 border border-gray-800 rounded space-y-2">
                        <div class="flex items-center gap-2">
                            <input type="checkbox" id="sSmartSplit" checked class="accent-custom-yellow h-4 w-4 rounded bg-gray-900 border-gray-700">
                            <label for="sSmartSplit" class="text-xs text-gray-300 font-bold cursor-pointer select-none text-custom-yellow">Smart Split Aktif</label>
                        </div>
                        <p class="text-[9px] text-gray-500">Panelleri kesmemek için kesim sınırına en yakın beyaz boşluğu otomatik tarar.</p>
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-[10px] font-bold text-gray-400 tracking-wider uppercase">ÇIKTI ZIP ADI</label>
                        <input type="text" id="sZipName" placeholder="dilimlenmis_webtoon_bolumu" class="w-full bg-[#181a22] border border-gray-700 rounded p-2 text-xs text-gray-200 focus:outline-none focus:border-custom-yellow">
                    </div>
                    <button onclick="compileSplitter()" class="w-full bg-orange-500 hover:bg-orange-600 text-black font-bold py-2.5 px-3 rounded text-xs flex items-center justify-center gap-1.5">
                        <i data-lucide="scissors" class="w-4 h-4"></i> DİLİMLE VE ZIP YAP
                    </button>
                </div>

                <div id="core-converter" class="engine-settings space-y-4 hidden">
                    <div class="p-3 bg-gray-950 border border-gray-800 rounded space-y-3">
                        <div class="text-custom-yellow font-bold text-[10px] flex justify-between">
                            <span>LAB FILTERS MATRIX</span>
                            <button onclick="resetLevels()" class="text-[9px] text-red-400 hover:text-red-300 underline">SIFIRLA</button>
                        </div>
                        <div>
                            <label class="text-[9px] text-gray-400 block">Siyah Nokta (Levels):</label>
                            <input type="range" id="lvlBlack" min="0" max="100" value="0" class="w-full accent-custom-yellow" oninput="updateLivePreview()">
                        </div>
                        <div>
                            <label class="text-[9px] text-gray-400 block">Beyaz Nokta (Levels):</label>
                            <input type="range" id="lvlWhite" min="150" max="255" value="255" class="w-full accent-custom-yellow" oninput="updateLivePreview()">
                        </div>
                        <div class="pt-2 border-t border-gray-900 space-y-1">
                            <label class="text-[10px] text-gray-300 font-bold block">Sharpen (Keskinleştirme Gücü):</label>
                            <input type="range" id="filterSharpenVal" min="0" max="5" step="0.5" value="0" class="w-full accent-custom-yellow" oninput="updateLivePreview()">
                            <p class="text-[8px] text-gray-500">0 = Pasif | Yukarı doğru sert hatlar</p>
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] text-gray-300 font-bold block">Manga Threshold (Eşik Griliği):</label>
                            <input type="range" id="filterThresholdVal" min="0" max="254" value="0" class="w-full accent-custom-yellow" oninput="updateLivePreview()">
                            <p class="text-[8px] text-gray-500">0 = Pasif | Siyah-Beyaz katılık dengesi</p>
                        </div>
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-[10px] font-bold text-gray-400 tracking-wider uppercase">HEDEF FORMAT</label>
                        <select id="cTargetFormat" class="w-full bg-[#181a22] border border-gray-700 rounded p-2 text-xs text-gray-200 focus:outline-none focus:border-custom-yellow">
                            <option value="image/webp">WebP (.webp)</option>
                            <option value="image/jpeg">JPEG (.jpg)</option>
                            <option value="image/png">PNG (.png)</option>
                        </select>
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-[10px] font-bold text-gray-400 tracking-wider uppercase">ÇIKTI ZIP ADI</label>
                        <input type="text" id="cZipName" placeholder="donusturulmus_sayfalar" class="w-full bg-[#181a22] border border-gray-700 rounded p-2 text-xs text-gray-200 focus:outline-none focus:border-custom-yellow">
                    </div>
                    <button onclick="compileConverter()" class="w-full bg-blue-500 hover:bg-blue-600 text-white font-bold py-2.5 px-3 rounded text-xs flex items-center justify-center gap-1.5">
                        <i data-lucide="refresh-cw" class="w-4 h-4"></i> TEMİZLE VE DÖNÜŞTÜR
                    </button>
                </div>

                <div id="core-renamer" class="engine-settings space-y-4 hidden">
                    <div class="space-y-1.5">
                        <label class="text-[10px] font-bold text-gray-400 tracking-wider uppercase">BASAMAK YAPISI</label>
                        <select id="rPadding" class="w-full bg-[#181a22] border border-gray-700 rounded p-2 text-xs text-gray-200 focus:outline-none focus:border-custom-yellow">
                            <option value="3">3 Basamaklı (001...)</option>
                            <option value="2">2 Basamaklı (01...)</option>
                            <option value="4">4 Basamaklı (0001...)</option>
                        </select>
                    </div>
                    <button onclick="compileRenamer()" class="w-full bg-emerald-500 hover:bg-emerald-600 text-black font-bold py-2.5 px-3 rounded text-xs flex items-center justify-center gap-1.5">
                        <i data-lucide="binary" class="w-4 h-4"></i> YENİDEN İNDEKSLE
                    </button>
                </div>

                <div id="core-watermark" class="engine-settings space-y-4 hidden">
                    <div class="p-3 bg-gray-950 rounded border border-gray-800 space-y-3">
                        <label class="w-full h-12 border border-dashed border-gray-800 hover:border-custom-yellow bg-[#111217] rounded flex flex-col items-center justify-center gap-1 text-[10px] text-gray-400 cursor-pointer transition-colors">
                            <i data-lucide="file-plus" class="w-3.5 h-3.5 text-custom-yellow"></i>
                            <span id="wm-label">Logo Seç (PNG)</span>
                            <input type="file" id="watermark-loader" accept="image/*" class="hidden" onchange="loadWatermark(event)">
                        </label>
                        <div class="space-y-2 pt-1 border-t border-gray-900">
                            <div>
                                <label class="text-[10px] text-gray-400 font-bold block mb-1">Opasite Seviyesi (%):</label>
                                <input type="number" id="wmOpacity" value="35" min="0" max="100" class="w-full bg-[#181a22] border border-gray-700 rounded p-1.5 text-xs focus:outline-none focus:border-custom-yellow" oninput="updateLivePreview()">
                            </div>
                            <div>
                                <label class="text-[10px] text-gray-400 font-bold block mb-1">Damgalama Düzeni:</label>
                                <select id="wmMode" onchange="toggleWatermarkSubSettings(); updateLivePreview();" class="w-full bg-[#181a22] border border-gray-700 rounded p-1.5 text-xs focus:outline-none focus:border-custom-yellow">
                                    <option value="center">Tam Sayfa Ortala</option>
                                    <option value="repeat">Dikey Periyodik</option>
                                </select>
                            </div>
                            <div id="wm-repeat-interval-box" class="hidden">
                                <label class="text-[10px] text-gray-400 font-bold block mb-1">Dikey Tekrar Aralığı (PX):</label>
                                <input type="number" id="wmInterval" value="2000" class="w-full bg-[#181a22] border border-gray-700 rounded p-1.5 text-xs focus:outline-none focus:border-custom-yellow" oninput="updateLivePreview()">
                            </div>
                        </div>
                    </div>
                    <button onclick="compileWatermarkOnly()" class="w-full bg-cyan-600 hover:bg-cyan-700 text-white font-bold py-2.5 px-3 rounded text-xs flex items-center justify-center gap-1.5 shadow-md">
                        <i data-lucide="image" class="w-4 h-4"></i> WATERMARK BAS VE ZIP YAP
                    </button>
                </div>
            </div>

            <div class="pt-4 border-t border-gray-800">
                <button onclick="wipeCore()" class="w-full text-center py-2 text-xs font-bold text-red-400 bg-red-500/5 hover:bg-red-500/10 border border-red-500/20 rounded transition-colors">
                    Havuz Matrisini Sıfırla
                </button>
            </div>
        </aside>

        <main class="flex-1 flex flex-col bg-[#0b0c10] relative">
            <div class="p-3 bg-[#111217]/50 border-b border-gray-800 flex items-center justify-between text-xs font-mono">
                <span id="file-count-badge" class="text-gray-400">Havuz Durumu: <strong class="text-custom-yellow">0 RAW Dosya</strong></span>
                <span class="text-gray-600">| Sürüm: <strong class="text-custom-yellow">V2.1</strong> | Mod: <strong id="current-mode-lbl" class="text-custom-yellow uppercase">merger</strong></span>
            </div>

            <div class="flex-1 overflow-hidden flex relative">
                <div id="masterGrid" class="flex-1 overflow-y-auto custom-scrollbar p-4 grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 xl:grid-cols-10 gap-2.5 content-start"></div>

                <div id="previewSidebar" class="w-[480px] bg-[#111217] border-l border-gray-800 flex flex-col hidden h-full z-10">
                    <div class="p-3 border-b border-gray-800 flex items-center justify-between bg-gray-950">
                        <span class="text-xs font-bold text-custom-yellow font-mono tracking-wider flex items-center gap-1"><i data-lucide="eye" class="w-3.5 h-3.5"></i> CANLI SIMÜLASYON</span>
                        <div class="flex items-center gap-2">
                            <button id="btnToggleSliderLine" onclick="toggleSliderLine()" class="bg-gray-800 hover:bg-gray-700 text-[10px] text-custom-yellow font-bold px-2 py-1 rounded border border-gray-700 flex items-center gap-1">
                                <i data-lucide="split" class="w-3 h-3"></i> A/B ÇİZGİSİNİ KAPAT
                            </button>
                            <button onclick="closePreviewSidebar()" class="text-gray-400 hover:text-white"><i data-lucide="x" class="w-4 h-4"></i></button>
                        </div>
                    </div>
                    <div class="flex-1 overflow-auto p-4 custom-scrollbar bg-black/60 flex items-start justify-center">
                        <div id="preview-container" class="comparison-slider border border-gray-800 rounded bg-[#0a0a0d] max-w-full shadow-2xl select-none">
                            <div id="before-container" class="resize">
                                <canvas id="canvasBefore" class="max-w-none h-auto block"></canvas>
                            </div>
                            <canvas id="canvasAfter" class="max-w-full h-auto block"></canvas>
                            <div id="sliderHandle" class="handle"></div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <div id="cropModal" class="fixed inset-0 bg-black/95 z-50 flex items-center justify-center hidden font-mono">
        <div class="bg-[#111217] border border-gray-800 rounded-lg p-5 w-[500px] h-[85vh] flex flex-col justify-between">
            <div class="text-xs font-bold text-custom-yellow flex items-center justify-between border-b border-gray-800 pb-2">
                <span><i data-lucide="crop" class="w-3.5 h-3.5 inline mr-1"></i> LIVE CANVAS CROPPER (PHOTOSHOP STYLE)</span>
                <button onclick="closeCropModal()" class="text-gray-400 hover:text-white"><i data-lucide="x" class="w-4 h-4"></i></button>
            </div>
            
            <p class="text-[9px] text-gray-500 my-1">Sarı çizgileri fareyle aşağı/yukarı sürükleyerek kırpılacak alanı görsel üstünde canlı ayarla.</p>

            <div class="flex-1 overflow-y-auto border border-gray-900 bg-gray-950 rounded p-2 custom-scrollbar relative flex justify-center items-start" id="cropCanvasWrapper">
                <div class="relative inline-block" id="cropContainer">
                    <img id="cropImgTarget" class="block max-w-full h-auto select-none pointer-events-none">
                    <div id="cropLineTop" class="crop-guide-line top-0" data-label="ÜST CROP"></div>
                    <div id="cropLineBottom" class="crop-guide-line bottom-0" data-label="ALT CROP"></div>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-3 mt-3 bg-gray-950 p-2 rounded border border-gray-900 text-xs text-center">
                <div>Üstten Tıraşlama: <strong id="lblCropTopPX" class="text-custom-yellow">0</strong> px</div>
                <div>Alttan Tıraşlama: <strong id="lblCropBotPX" class="text-custom-yellow">0</strong> px</div>
            </div>

            <button onclick="applyManualCrop()" class="w-full bg-custom-yellow text-black font-bold py-2.5 rounded text-xs mt-3 shadow-md">
                KIRPMAYI MATRİSE GÖM
            </button>
        </div>
    </div>

    <div id="matrixOverlay" class="fixed inset-0 bg-black/85 backdrop-filter backdrop-blur-sm z-50 flex items-center justify-center hidden">
        <div class="bg-[#111217] border border-custom-yellow/40 p-6 rounded-lg w-96 text-center font-mono">
            <div id="mTitle" class="text-xs font-bold text-custom-yellow uppercase tracking-widest mb-1">PIPELINE RUNNING...</div>
            <div id="mStatus" class="text-[10px] text-gray-500 truncate mb-4">İşlemler yürütülüyor...</div>
            <div class="w-full bg-gray-950 h-1.5 rounded-full overflow-hidden border border-gray-800 mb-2">
                <div id="mBar" class="bg-custom-yellow h-full w-0 transition-all duration-100"></div>
            </div>
            <div id="mPercent" class="text-xl font-black text-white">%0</div>
        </div>
    </div>

    <button onclick="toggleLivePreviewSidebar()" class="fixed bottom-10 right-6 z-30 bg-amber-500 hover:bg-amber-600 text-gray-950 font-bold p-3.5 rounded-full flex items-center justify-center shadow-2xl transition-transform hover:scale-105 active:scale-95 group">
        <i data-lucide="eye" class="w-5 h-5"></i>
        <span class="max-w-0 overflow-hidden group-hover:max-w-xs group-hover:ml-2 transition-all duration-300 ease-out text-xs font-mono whitespace-nowrap">LIVE FILTERS</span>
    </button>

    <script>
        let masterData = [];
        let selectedIndices = [];
        let designGroups = [];
        let currentGroupCounter = 1;
        let lastSelectedIndex = null;
        let engineActiveMode = 'merger';
        let watermarkImgData = null;
        let historyStack = [];
        
        let currentCropIndex = null;
        let cropTopPx = 0;
        let cropBotPx = 0;
        let isLineActive = true; 

        lucide.createIcons();

        window.addEventListener('DOMContentLoaded', () => {
            const savedState = localStorage.getItem('scanlation_toolkit_autosave_v21');
            if (savedState) {
                try {
                    const parsed = JSON.parse(savedState);
                    masterData = parsed.masterData || [];
                    designGroups = parsed.designGroups || [];
                    currentGroupCounter = parsed.currentGroupCounter || 1;
                    watermarkImgData = parsed.watermarkImgData || null;
                    if(watermarkImgData && document.getElementById('wm-label')) document.getElementById('wm-label').innerText = "Logo Sistemde";
                    renderWorkspace();
                } catch(e) { console.error("Hafıza bozuk."); }
            }
            toggleMergerAutoUI();
            initABSlider();
            initCropDragEngine();
            initDragDrop();
        });

        function toggleMergerAutoUI() {
            const isAuto = document.getElementById('mAutoMode').checked;
            document.getElementById('mAutoHeightBox').classList.toggle('hidden', !isAuto);
            document.getElementById('mManualButtons').classList.toggle('hidden', isAuto);
            renderWorkspace();
        }

        function autoSaveState() {
            const state = { masterData, designGroups, currentGroupCounter, watermarkImgData };
            localStorage.setItem('scanlation_toolkit_autosave_v21', JSON.stringify(state));
            const badge = document.getElementById('save-status');
            if (badge) {
                badge.innerText = "KAYDEDİLDİ"; badge.className = "text-amber-400 font-bold";
                setTimeout(() => { badge.innerText = "AKTİF"; badge.className = "text-emerald-400 font-bold"; }, 1000);
            }
        }

        function saveHistorySnapshot() {
            if (historyStack.length > 20) historyStack.shift();
            historyStack.push(JSON.stringify({ masterData, selectedIndices, designGroups, currentGroupCounter }));
        }

        function changeEngine(mode) {
            engineActiveMode = mode;
            document.getElementById('current-mode-lbl').innerText = mode;
            document.querySelectorAll('header button').forEach(b => b.className = "px-3 py-1.5 rounded text-xs font-bold transition-all border flex items-center gap-1.5 bg-gray-900 border-gray-800 text-gray-400 hover:text-white");
            document.getElementById(`tab-${mode}`).className = "px-3 py-1.5 rounded text-xs font-bold transition-all border flex items-center gap-1.5 bg-[#ecec00]/10 border-custom-yellow text-custom-yellow";
            document.querySelectorAll('.engine-settings').forEach(p => p.classList.add('hidden'));
            document.getElementById(`core-${mode}`).classList.remove('hidden');
            renderWorkspace();
            updateLivePreview();
        }

        window.addEventListener('keydown', (e) => {
            if (e.target.tagName === 'INPUT' || e.target.tagName === 'SELECT') return;
            if (e.ctrlKey && e.key.toLowerCase() === 'z' && historyStack.length > 0) {
                e.preventDefault();
                const snap = JSON.parse(historyStack.pop());
                masterData = snap.masterData; selectedIndices = snap.selectedIndices; designGroups = snap.designGroups; currentGroupCounter = snap.currentGroupCounter;
                renderWorkspace(); autoSaveState();
            }
        });

        function processFiles(event) {
            const files = Array.from(event.target.files);
            loadFilesArray(files);
        }

        function loadFilesArray(files) {
            if (files.length === 0) return;
            saveHistorySnapshot();
            let loaded = 0; masterData = []; selectedIndices = []; designGroups = []; currentGroupCounter = 1;
            showMatrixProgress("RAW_LOADING", "Görseller sisteme yükleniyor...", 20);

            files.forEach(file => {
                if (!file.type.startsWith('image/')) return;
                const r = new FileReader();
                r.onload = (e) => {
                    masterData.push({ name: file.name, src: e.target.result, assignedGroup: null });
                    loaded++;
                    if (loaded === files.length) {
                        masterData.sort((a, b) => a.name.localeCompare(b.name, undefined, {numeric: true, sensitivity: 'base'}));
                        document.getElementById('matrixOverlay').classList.add('hidden');
                        renderWorkspace(); autoSaveState(); updateLivePreview();
                    }
                };
                r.readAsDataURL(file);
            });
        }

        /* ── SÜRÜKLE-BIRAK MOTORU ── */
        function initDragDrop() {
            const globalZone = document.getElementById('global-drop-zone');
            let dragCounter = 0;

            // Tüm sayfa üzerinde drag olaylarını yakala
            document.addEventListener('dragenter', (e) => {
                e.preventDefault();
                dragCounter++;
                if (dragCounter === 1) {
                    globalZone.classList.remove('hidden');
                    globalZone.classList.add('active');
                    lucide.createIcons();
                }
            });

            document.addEventListener('dragleave', (e) => {
                dragCounter--;
                if (dragCounter === 0) {
                    globalZone.classList.add('hidden');
                    globalZone.classList.remove('active');
                }
            });

            document.addEventListener('dragover', (e) => {
                e.preventDefault();
            });

            document.addEventListener('drop', (e) => {
                e.preventDefault();
                dragCounter = 0;
                globalZone.classList.add('hidden');
                globalZone.classList.remove('active');
                const files = Array.from(e.dataTransfer.files).filter(f => f.type.startsWith('image/'));
                if (files.length > 0) {
                    saveHistorySnapshot();
                    masterData = []; selectedIndices = []; designGroups = []; currentGroupCounter = 1;
                    showMatrixProgress("RAW_LOADING", "Sürüklenen görseller yükleniyor...", 20);
                    loadFilesArray(files);
                }
            });

            // Sidebar yükleme alanı için özel stil
            const uploadZone = document.getElementById('upload-drop-zone');
            if (uploadZone) {
                uploadZone.addEventListener('dragenter', () => uploadZone.classList.add('drag-over-upload'));
                uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('drag-over-upload'));
                uploadZone.addEventListener('drop', () => uploadZone.classList.remove('drag-over-upload'));
            }
        }

        function renderWorkspace() {
            const grid = document.getElementById('masterGrid'); grid.innerHTML = '';
            document.getElementById('file-count-badge').innerHTML = `Havuz: <strong class="text-custom-yellow">${masterData.length} RAW</strong>`;
            const isAuto = (engineActiveMode === 'merger' && document.getElementById('mAutoMode').checked);

            masterData.forEach((item, idx) => {
                const card = document.createElement('div');
                card.className = 'bg-[#121319] border border-gray-800 rounded p-1.5 text-center relative group transition-all select-none cursor-pointer hover:border-gray-600';
                if (!isAuto && engineActiveMode === 'merger') {
                    if (item.assignedGroup) card.classList.add(`gc-${((item.assignedGroup - 1) % 5) + 1}`);
                    if (selectedIndices.includes(idx)) card.className += ' !border-white bg-gray-800/40';
                }

                card.innerHTML = `
                    <div class="w-full aspect-[3/4] bg-black/40 rounded flex items-center justify-center overflow-hidden mb-1">
                        <img src="${item.src}" class="max-w-full max-h-24 object-contain pointer-events-none">
                    </div>
                    <p class="text-[9px] font-mono text-gray-500 truncate" title="${item.name}">${item.name}</p>
                    ${(item.assignedGroup && !isAuto) ? `<span class="inline-block text-[8px] font-bold px-1 py-0.5 rounded mt-1 bg-black/40">G-${item.assignedGroup}</span>` : ''}
                    <div class="absolute top-1 left-1 bg-black/70 px-1 text-[8px] rounded font-mono text-gray-400 border border-gray-800">${idx + 1}</div>
                `;

                card.addEventListener('click', (e) => {
                    if (!isAuto && engineActiveMode === 'merger' && !item.assignedGroup) {
                        saveHistorySnapshot();
                        if (e.shiftKey && lastSelectedIndex !== null) {
                            selectedIndices = [];
                            let s = Math.min(lastSelectedIndex, idx), end = Math.max(lastSelectedIndex, idx);
                            for (let i = s; i <= end; i++) if (!masterData[i].assignedGroup) selectedIndices.push(i);
                        } else {
                            if (selectedIndices.includes(idx)) selectedIndices = selectedIndices.filter(i => i !== idx);
                            else selectedIndices.push(idx);
                            lastSelectedIndex = idx;
                        }
                        renderWorkspace(); autoSaveState();
                    }
                });

                card.addEventListener('dblclick', () => openCropModal(idx));
                grid.appendChild(card);
            });
        }

        function buildGroup() {
            if (selectedIndices.length === 0) return;
            saveHistorySnapshot();
            selectedIndices.sort((a,b)=>a-b).forEach(i => masterData[i].assignedGroup = currentGroupCounter);
            designGroups.push({ id: currentGroupCounter, mapping: [...selectedIndices] });
            currentGroupCounter++; selectedIndices = []; lastSelectedIndex = null;
            renderWorkspace(); autoSaveState();
        }

        /* PHOTOSHOP CROP SÜRÜKLEME SİSTEMİ */
        let activeLine = null;
        let imgOrigH = 0;

        async function openCropModal(idx) {
            currentCropIndex = idx;
            const item = masterData[idx];
            const imgEl = document.getElementById('cropImgTarget');
            imgEl.src = item.src;
            
            await new Promise(res => imgEl.onload = res);
            
            imgOrigH = imgEl.naturalHeight;
            cropTopPx = 0;
            cropBotPx = 0;
            
            document.getElementById('cropLineTop').style.top = '0px';
            document.getElementById('cropLineBottom').style.top = (imgEl.offsetHeight - 2) + 'px';
            
            updateCropLabels();
            document.getElementById('cropModal').classList.remove('hidden');
        }

        function closeCropModal() { document.getElementById('cropModal').classList.add('hidden'); }

        function initCropDragEngine() {
            const container = document.getElementById('cropContainer');
            const lineTop = document.getElementById('cropLineTop');
            const lineBot = document.getElementById('cropLineBottom');

            const onMouseDown = (e, line) => { e.preventDefault(); activeLine = line; };
            lineTop.addEventListener('mousedown', (e) => onMouseDown(e, 'top'));
            lineBot.addEventListener('mousedown', (e) => onMouseDown(e, 'bottom'));

            window.addEventListener('mousemove', (e) => {
                if (!activeLine) return;
                const rect = container.getBoundingClientRect();
                let relativeY = e.clientY - rect.top;
                relativeY = Math.max(0, Math.min(rect.height, relativeY));

                let scale = imgOrigH / rect.height;

                if (activeLine === 'top') {
                    let botLineY = parseFloat(lineBot.style.top) || rect.height;
                    if (relativeY >= botLineY - 10) relativeY = botLineY - 10;
                    lineTop.style.top = relativeY + 'px';
                    cropTopPx = Math.round(relativeY * scale);
                } else if (activeLine === 'bottom') {
                    let topLineY = parseFloat(lineTop.style.top) || 0;
                    if (relativeY <= topLineY + 10) relativeY = topLineY + 10;
                    lineBot.style.top = relativeY + 'px';
                    cropBotPx = Math.round((rect.height - relativeY) * scale);
                }
                updateCropLabels();
            });

            window.addEventListener('mouseup', () => activeLine = null);
        }

        function updateCropLabels() {
            document.getElementById('lblCropTopPX').innerText = cropTopPx;
            document.getElementById('lblCropBotPX').innerText = cropBotPx;
        }

        async function applyManualCrop() {
            if(currentCropIndex === null) return;
            saveHistorySnapshot();

            const img = new Image(); img.src = masterData[currentCropIndex].src;
            await new Promise(res => img.onload = res);

            let newH = img.height - cropTopPx - cropBotPx;
            if(newH <= 10) { alert("Çok fazla kırptın kanka, panel yok oldu!"); return; }

            const canvas = document.createElement('canvas'); canvas.width = img.width; canvas.height = newH;
            const ctx = canvas.getContext('2d');
            ctx.drawImage(img, 0, cropTopPx, img.width, newH, 0, 0, img.width, newH);

            masterData[currentCropIndex].src = canvas.toDataURL('image/webp', 0.95);
            closeCropModal(); renderWorkspace(); autoSaveState(); updateLivePreview();
        }

        /* A/B ÇİZGİSİNİ TETİKLEME / KAPATMA */
        function toggleSliderLine() {
            const container = document.getElementById('preview-container');
            const btn = document.getElementById('btnToggleSliderLine');
            isLineActive = !isLineActive;

            if (isLineActive) {
                container.classList.remove('disabled');
                btn.innerHTML = `<i data-lucide="split" class="w-3 h-3"></i> A/B ÇİZGİSİNİ KAPAT`;
            } else {
                container.classList.add('disabled');
                btn.innerHTML = `<i data-lucide="eye" class="w-3 h-3"></i> A/B ÇİZGİSİNİ AÇ`;
            }
            lucide.createIcons();
            updateLivePreview();
        }

        function loadWatermark(event) {
            const f = event.target.files[0]; if(!f) return;
            const reader = new FileReader();
            reader.onload = (e) => { watermarkImgData = e.target.result; document.getElementById('wm-label').innerText = "Logo Sistemde"; autoSaveState(); updateLivePreview(); };
            reader.readAsDataURL(f);
        }

        function toggleLivePreviewSidebar() {
            if(masterData.length === 0) return;
            document.getElementById('previewSidebar').classList.toggle('hidden');
            updateLivePreview();
        }
        function closePreviewSidebar() { document.getElementById('previewSidebar').classList.add('hidden'); }

        async function updateLivePreview() {
            if (document.getElementById('previewSidebar').classList.contains('hidden') || masterData.length === 0) return;
            const canvasB = document.getElementById('canvasBefore'), canvasA = document.getElementById('canvasAfter');
            const ctxB = canvasB.getContext('2d'), ctxA = canvasA.getContext('2d');

            const img = new Image(); img.src = masterData[0].src;
            await new Promise(res => img.onload = res);

            canvasB.width = img.width; canvasB.height = img.height;
            canvasA.width = img.width; canvasA.height = img.height;
            ctxB.drawImage(img, 0, 0); ctxA.drawImage(img, 0, 0);

            applyFiltersPipeline(ctxA, img.width, img.height);
            canvasB.style.width = canvasA.getBoundingClientRect().width + 'px';
        }

        /* YOĞUNLUK AYARLI FİLTRE MOTORU */
        function applyFiltersPipeline(ctx, w, h) {
            let b = parseInt(document.getElementById('lvlBlack').value);
            let wh = parseInt(document.getElementById('lvlWhite').value);
            let imgData = ctx.getImageData(0, 0, w, h);
            let data = imgData.data;

            let threshVal = parseInt(document.getElementById('filterThresholdVal').value);

            // Levels & Threshold
            for (let i = 0; i < data.length; i += 4) {
                for (let j = 0; j < 3; j++) {
                    let val = Math.min(255, Math.max(0, ((data[i + j] - b) / (wh - b)) * 255));
                    if(threshVal > 0) {
                        val = val > threshVal ? 255 : 0;
                    }
                    data[i + j] = val;
                }
            }
            ctx.putImageData(imgData, 0, 0);

            // Yoğunluk Ayarlı Sharpen (Convolution)
            let sharpenPower = parseFloat(document.getElementById('filterSharpenVal').value);
            if(sharpenPower > 0) {
                // Merkez değer güce göre artar, çevre değerleri dengelenir
                let c = 1 + (4 * sharpenPower);
                let edge = -sharpenPower;
                let weights = [0, edge, 0, edge, c, edge, 0, edge, 0], side = 3;
                let src = data;
                let output = ctx.createImageData(w, h);
                let dst = output.data;
                for (let y=0; y<h; y++) {
                    for (let x=0; x<w; x++) {
                        let sy = y, sx = x, dstOff = (y*w+x)*4;
                        let r=0, g=0, b_val=0;
                        for (let cy=0; cy<side; cy++) {
                            for (let cx=0; cx<side; cx++) {
                                let scy = Math.min(h-1, Math.max(0, sy + cy - 1));
                                let scx = Math.min(w-1, Math.max(0, sx + cx - 1));
                                let srcOff = (scy*w+scx)*4;
                                let wt = weights[cy*side+cx];
                                r += src[srcOff] * wt; g += src[srcOff+1] * wt; b_val += src[srcOff+2] * wt;
                            }
                        }
                        dst[dstOff] = r; dst[dstOff+1] = g; dst[dstOff+2] = b_val; dst[dstOff+3] = src[dstOff+3];
                    }
                }
                ctx.putImageData(output, 0, 0);
            }
        }

        /* SMART SPLITTER ENGINE */
        async function compileSplitter() {
            if(masterData.length === 0) return;
            let targetMaxH = parseInt(document.getElementById('sHeight').value) || 3500;
            let isSmart = document.getElementById('sSmartSplit').checked;
            let zipName = document.getElementById('sZipName').value.trim() || "dilimlenmis_webtoon_bolumu";
            const zip = new JSZip(); let fileIdx = 1;

            for(let i=0; i<masterData.length; i++) {
                showMatrixProgress("SPLITTING", `Sayfa taranıyor: ${i+1}/${masterData.length}`, Math.round((i/masterData.length)*80));
                const img = new Image(); img.src = masterData[i].src;
                await new Promise(res => img.onload = res);

                let trackerY = 0;
                while(trackerY < img.height) {
                    let remainingH = img.height - trackerY;
                    let currentSliceH = Math.min(targetMaxH, remainingH);

                    if (isSmart && remainingH > targetMaxH) {
                        const tempCanvas = document.createElement('canvas'); tempCanvas.width = img.width; tempCanvas.height = currentSliceH;
                        const tempCtx = tempCanvas.getContext('2d');
                        tempCtx.drawImage(img, 0, trackerY, img.width, currentSliceH, 0, 0, img.width, currentSliceH);
                        let imgData = tempCtx.getImageData(0, 0, img.width, currentSliceH);
                        let data = imgData.data;

                        let foundSmartY = -1;
                        let scanRange = Math.min(400, currentSliceH - 100);
                        for (let checkY = currentSliceH - 1; checkY >= currentSliceH - scanRange; checkY--) {
                            let isWhiteRow = true;
                            for (let x = 0; x < img.width; x += 5) {
                                let idx = (checkY * img.width + x) * 4;
                                if (data[idx] < 240 || data[idx+1] < 240 || data[idx+2] < 240) { isWhiteRow = false; break; }
                            }
                            if (isWhiteRow) { foundSmartY = checkY; break; }
                        }
                        if (foundSmartY !== -1) { currentSliceH = foundSmartY; }
                    }

                    const canvas = document.createElement('canvas'); canvas.width = img.width; canvas.height = currentSliceH;
                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(img, 0, trackerY, img.width, currentSliceH, 0, 0, img.width, currentSliceH);

                    await new Promise(res => canvas.toBlob(blob => {
                        zip.file(`${String(fileIdx).padStart(3, '0')}.webp`, blob); fileIdx++;
                        res();
                    }, 'image/webp', 0.95));

                    trackerY += currentSliceH;
                }
            }
            packAndShip(zip, zipName);
        }

        async function compileMerger() {
            if (masterData.length === 0) return;
            const isAuto = document.getElementById('mAutoMode').checked;
            let zipName = document.getElementById('mZipName').value.trim() || "birlesmis_bolum_panelleri";
            const zip = new JSZip();

            if (isAuto) {
                let maxH = parseInt(document.getElementById('mTargetHeight').value) || 8000;
                let batch = []; let accumH = 0; let fIdx = 1;
                for (let i = 0; i < masterData.length; i++) {
                    const img = await new Promise(res => { const im = new Image(); im.src = masterData[i].src; im.onload = () => res(im); });
                    let bW = batch.length > 0 ? batch[0].img.width : img.width;
                    let sH = img.height * (bW / img.width);
                    if (accumH + sH > maxH && batch.length > 0) {
                        await buildSingleMergedFile(zip, batch, fIdx++); batch = []; accumH = 0; bW = img.width; sH = img.height;
                    }
                    batch.push({ img, scaledH: sH }); accumH += sH;
                }
                if (batch.length > 0) await buildSingleMergedFile(zip, batch, fIdx);
            } else {
                if (designGroups.length === 0) return;
                for (let g = 0; g < designGroups.length; g++) {
                    const targets = designGroups[g].mapping.map(i => masterData[i]);
                    const imgs = await Promise.all(targets.map(t => new Promise(res => { const im = new Image(); im.src = t.src; im.onload = () => res(im); })));
                    let bW = imgs[0].width;
                    let bData = imgs.map(im => { let sh = im.height * (bW / im.width); return { img: im, scaledH: sh }; });
                    await buildSingleMergedFile(zip, bData, g + 1);
                }
            }
            packAndShip(zip, zipName);
        }

        async function buildSingleMergedFile(zip, batch, index) {
            const canvas = document.createElement('canvas'); canvas.width = batch[0].img.width; canvas.height = batch.reduce((s, i) => s + i.scaledH, 0);
            const ctx = canvas.getContext('2d'); let offset = 0;
            batch.forEach(item => { ctx.drawImage(item.img, 0, offset, canvas.width, item.scaledH); offset += item.scaledH; });
            await new Promise(res => canvas.toBlob(blob => { zip.file(`${String(index).padStart(3, '0')}.webp`, blob); res(); }, 'image/webp', 0.92));
        }

        async function compileConverter() {
            if(masterData.length === 0) return;
            let format = document.getElementById('cTargetFormat').value;
            let zipName = document.getElementById('cZipName').value.trim() || "donusturulmus_sayfalar";
            let ext = format === "image/jpeg" ? ".jpg" : (format === "image/png" ? ".png" : ".webp");
            const zip = new JSZip();

            for(let i=0; i<masterData.length; i++) {
                showMatrixProgress("FILTERS_COMPILING", `İşleniyor: ${i+1}`, Math.round((i/masterData.length)*80));
                const img = await new Promise(res => { const im = new Image(); im.src = masterData[i].src; im.onload = () => res(im); });
                const canvas = document.createElement('canvas'); canvas.width = img.width; canvas.height = img.height;
                const ctx = canvas.getContext('2d'); ctx.drawImage(img, 0, 0);

                if(format === "image/jpeg") { ctx.globalCompositeOperation = 'destination-over'; ctx.fillStyle = '#ffffff'; ctx.fillRect(0,0,img.width,img.height); ctx.globalCompositeOperation = 'source-over'; }
                applyFiltersPipeline(ctx, img.width, img.height);

                let name = masterData[i].name.substring(0, masterData[i].name.lastIndexOf('.')) || masterData[i].name;
                await new Promise(res => canvas.toBlob(blob => { zip.file(`${name}${ext}`, blob); res(); }, format, 0.90));
            }
            packAndShip(zip, zipName);
        }

        async function compileRenamer() {
            if(masterData.length === 0) return;
            let pad = parseInt(document.getElementById('rPadding').value), zip = new JSZip();
            for(let i=0; i<masterData.length; i++) {
                const img = await new Promise(res => { const im = new Image(); im.src = masterData[i].src; im.onload = () => res(im); });
                const canvas = document.createElement('canvas'); canvas.width = img.width; canvas.height = img.height;
                canvas.getContext('2d').drawImage(img, 0, 0);
                await new Promise(res => canvas.toBlob(blob => { zip.file(String(i+1).padStart(pad, '0') + ".webp", blob); res(); }, 'image/webp', 0.92));
            }
            packAndShip(zip, "sirali_sayfalar");
        }

        function packAndShip(zip, name) {
            showMatrixProgress("PACKING", "ZIP paketi derleniyor...", 92);
            zip.generateAsync({type: "blob"}).then(blob => {
                const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = `${name}.zip`; a.click();
                setTimeout(() => { URL.revokeObjectURL(a.href); document.getElementById('matrixOverlay').classList.add('hidden'); }, 1000);
            });
        }

        function showMatrixProgress(title, log, ratio) {
            document.getElementById('matrixOverlay').classList.remove('hidden');
            document.getElementById('mTitle').innerText = title; document.getElementById('mStatus').innerText = log;
            document.getElementById('mBar').style.width = `${ratio}%`; document.getElementById('mPercent').innerText = `%${ratio}`;
        }

        function initABSlider() {
            const slider = document.getElementById('preview-container'), resizeDiv = document.getElementById('before-container'), handle = document.getElementById('sliderHandle');
            let dragging = false;
            const move = (x) => {
                if(!isLineActive) return;
                let rect = slider.getBoundingClientRect();
                let pos = Math.max(0, Math.min(100, ((x - rect.left) / rect.width) * 100));
                resizeDiv.style.width = pos + '%'; handle.style.left = pos + '%';
            };
            handle.addEventListener('mousedown', () => dragging = true);
            window.addEventListener('mouseup', () => dragging = false);
            window.addEventListener('mousemove', (e) => dragging && move(e.clientX));
        }

        function wipeCore() {
            if(confirm("Mevcut işlem havuzu ve yerel kurtarma hafızası sıfırlansın mı kanka?")) {
                masterData = []; selectedIndices = []; designGroups = []; currentGroupCounter = 1; watermarkImgData = null;
                localStorage.removeItem('scanlation_toolkit_autosave_v21');
                document.getElementById('masterGrid').innerHTML = ''; closePreviewSidebar(); renderWorkspace();
            }
        }

        function resetLevels() {
            document.getElementById('lvlBlack').value = 0; document.getElementById('lvlWhite').value = 255;
            document.getElementById('filterSharpenVal').value = 0; document.getElementById('filterThresholdVal').value = 0;
            updateLivePreview();
        }
    </script>
</body>
</html>
